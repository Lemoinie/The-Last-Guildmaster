{
  "name": "the-last-guildmaster",
  "version": "0.1.0",
  "description": "A single-player RPG guild management game.",
  "repository": "https://github.com/Lemoinie/The-Last-Guildmaster",
  "main": "./out/main/index.js",
  "author": {
    "name": "Lemoinine"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postbuild": "electron-builder build --win",
    "start": "electron-vite preview"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "electron": "^41.2.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^5.0.0",
    "svelte": "^5.55.4",
    "typescript": "^6.0.2",
    "vite": "^6.4.2"
  },
  "build": {
    "appId": "com.lemoinine.lastguildmaster",
    "productName": "The Last Guildmaster",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      { "from": "legal", "to": "legal" },
      { "from": "assets", "to": "assets" }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "runAfterFinish": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "marked": "^18.0.0"
  }
}
