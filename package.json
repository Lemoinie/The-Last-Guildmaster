{
  "name": "the-last-guildmaster",
  "version": "0.1.0",
  "description": "A single-player RPG guild management game.",
  "repository": "https://github.com/Lemoinie/The-Last-Guildmaster",
  "main": "main.js",
  "author": {
    "name": "Lemoinie"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.lemoinie.lastguildmaster",
    "productName": "The Last Guildmaster",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "runAfterFinish": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}